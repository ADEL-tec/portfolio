# Public template of the runtime environment. Copy to `.env.local` and fill
# in real values (`.env.local` is git-ignored). Never commit secrets.

# ─── Server-only ──────────────────────────────────────────────────────────

# Anthropic API key — only used by /api/claude. Leave blank in environments
# where the chat assistant isn't surfaced (the route is excluded from the
# GitHub Pages deploy anyway).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Public (embedded into the client bundle) ─────────────────────────────

# Origin used for canonical URLs, OG tags, sitemap, JSON-LD.
# Examples:
#   https://adel-tec.github.io/portfolio   (GitHub Pages, current)
#   https://yourdomain.com                 (custom domain on Vercel/Netlify)
#   http://localhost:3000                  (local dev — set in .env.local)
NEXT_PUBLIC_SITE_URL=https://adel-tec.github.io/portfolio

# Sub-path under which the app is hosted. Required only for static export to
# GitHub Pages — leave empty when deploying to a host that serves at root.
# Must NOT have a trailing slash. The CI workflow sets it to `/portfolio`.
NEXT_PUBLIC_BASE_PATH=

# Default UI locale shown when no locale prefix is in the URL.
# Must match one of the locales declared in `i18n/routing.ts`.
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ─── Optional analytics / observability ───────────────────────────────────

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Plausible Analytics domain (alternative to GA). Leave blank to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
